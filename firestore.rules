rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - users can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Allow admins to read all users and update user roles
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow update: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Assessments collection (legacy)
    match /assessments/{assessmentId} {
      // Users can create their own assessments
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Users can read/write their own assessments
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Admins can read all assessments
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Assessment Templates collection
    match /assessmentTemplates/{templateId} {
      // Everyone can read active templates
      allow read: if true;
      
      // Only admins can create/update/delete templates
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // User Assessments collection
    match /userAssessments/{userAssessmentId} {
      // Users can create their own assessments
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      
      // Users can read/write their own assessments
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Admins can read all user assessments
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Admins collection
    match /admins/{adminId} {
      // Users can read their own admin status
      allow read: if request.auth != null && request.auth.uid == adminId;
      // Admins can read all admin documents and manage admin roles
      allow read: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      // Allow users to create their own admin document (for setup-admin page)
      allow create: if request.auth != null && request.auth.uid == adminId;
    }
    
    // Questions collection (optional, if you want dynamic questions)
    match /questions/{questionId} {
      // Everyone can read questions
      allow read: if true;
      
      // Only admins can write questions
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      // Allow admins to delete questions
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Categories collection
    match /categories/{categoryId} {
      // Everyone can read categories
      allow read: if true;
      
      // Only admins can write categories
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      // Allow admins to delete categories
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Score Levels collection
    match /scoreLevels/{levelId} {
      // Everyone can read score levels
      allow read: if true;
      
      // Only admins can write score levels
      allow write: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      // Allow admins to delete score levels
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Notifications collection
    match /notifications/{notificationId} {
      // Users can read their own notifications
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Only admins can create notifications
      allow create: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      // Users can update their own notifications (to mark as read/dismissed)
      allow update: if request.auth != null && 
                      request.auth.uid == resource.data.userId &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'dismissed']);
      
      // Only admins can delete notifications
      allow delete: if request.auth != null && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
  }
}
